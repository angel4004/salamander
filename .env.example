TELEGRAM_BOT_TOKEN=
MODEL_BACKEND=openclaw_gateway
ALLOWED_TELEGRAM_USER_IDS=
SESSION_FILE_PATH=data/sessions.json
SESSION_TURNS=12
SYSTEM_PROMPT_PATH=config/system-prompt.md
CPO_REPOSITORY_PATH=
CPO_GITHUB_URL=https://github.com/angel4004/cpo
CPO_BRANCH=main
CPO_AUTO_UPDATE=true

# Required only when MODEL_BACKEND=openai_api
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=medium
# OPENAI_BASE_URL=https://your-compatible-openai-relay/v1

# Required only when MODEL_BACKEND=openclaw_gateway
OPENCLAW_AGENT_ID=your-openclaw-agent
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_THINKING=medium
OPENCLAW_TIMEOUT_SECONDS=600
